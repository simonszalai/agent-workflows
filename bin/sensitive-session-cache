#!/usr/bin/env python3
"""Memory-only cache for sensitive `op read` results, scoped to one agent session."""

from __future__ import annotations

import base64
import hashlib
import json
import os
import socket
import subprocess
import sys
import time
from pathlib import Path

IDLE_TTL_SECONDS = 8 * 60 * 60


def socket_path() -> Path:
    session_id = os.environ.get("CONDUCTOR_SESSION_ID", "")
    if not session_id:
        raise SystemExit(2)
    digest = hashlib.sha256(session_id.encode()).hexdigest()[:24]
    # macOS limits AF_UNIX paths to roughly 104 bytes; Conductor/TMPDIR paths
    # are often much longer. Keep the user-private socket root short.
    root = Path("/tmp") / f"agent-sensitive-cache-{os.getuid()}"
    root.mkdir(mode=0o700, parents=True, exist_ok=True)
    os.chmod(root, 0o700)
    return root / f"{digest}.sock"


def request(payload: dict[str, str], *, retry: bool = True) -> dict[str, str]:
    path = socket_path()
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
            client.connect(str(path))
            client.sendall(json.dumps(payload).encode() + b"\n")
            response = b""
            while not response.endswith(b"\n"):
                chunk = client.recv(65536)
                if not chunk:
                    break
                response += chunk
        return json.loads(response)
    except (FileNotFoundError, ConnectionRefusedError, json.JSONDecodeError):
        if not retry:
            return {"status": "miss"}
        path.unlink(missing_ok=True)
        subprocess.Popen(
            [sys.executable, str(Path(__file__).resolve()), "_serve", str(path)],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
            close_fds=True,
        )
        for _ in range(40):
            if path.exists():
                break
            time.sleep(0.025)
        return request(payload, retry=False)


def serve(path: Path) -> None:
    path.unlink(missing_ok=True)
    values: dict[str, bytes] = {}
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
        server.bind(str(path))
        os.chmod(path, 0o600)
        server.listen(8)
        server.settimeout(IDLE_TTL_SECONDS)
        try:
            while True:
                try:
                    connection, _ = server.accept()
                except TimeoutError:
                    return
                with connection:
                    raw = b""
                    while not raw.endswith(b"\n"):
                        chunk = connection.recv(65536)
                        if not chunk:
                            break
                        raw += chunk
                    command = json.loads(raw)
                    action = command.get("action")
                    key = command.get("key", "")
                    if action == "get" and key in values:
                        response = {
                            "status": "hit",
                            "value": base64.b64encode(values[key]).decode(),
                        }
                    elif action == "put":
                        values[key] = base64.b64decode(command["value"])
                        response = {"status": "stored"}
                    elif action == "clear":
                        values.clear()
                        response = {"status": "cleared"}
                    elif action == "stop":
                        values.clear()
                        connection.sendall(b'{"status":"stopped"}\n')
                        return
                    else:
                        response = {"status": "miss"}
                    connection.sendall(json.dumps(response).encode() + b"\n")
        finally:
            values.clear()
            path.unlink(missing_ok=True)


def main() -> int:
    if len(sys.argv) >= 3 and sys.argv[1] == "_serve":
        serve(Path(sys.argv[2]))
        return 0
    if len(sys.argv) != 3 or sys.argv[1] not in {"get", "put", "clear", "stop"}:
        return 2
    action, key = sys.argv[1:]
    if action == "put":
        value = sys.stdin.buffer.read()
        response = request(
            {"action": "put", "key": key, "value": base64.b64encode(value).decode()}
        )
    else:
        response = request({"action": action, "key": key})
    if response.get("status") == "hit":
        sys.stdout.buffer.write(base64.b64decode(response["value"]))
        return 0
    return 0 if response.get("status") in {"stored", "cleared", "stopped"} else 1


if __name__ == "__main__":
    raise SystemExit(main())
