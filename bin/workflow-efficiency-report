#!/usr/bin/env python3
"""Report bounded whole-tree workflow efficiency from Codex rollout logs."""

from __future__ import annotations

import argparse
import hashlib
import json
import re
from collections import Counter, defaultdict, deque
from datetime import datetime, timedelta, timezone
from pathlib import Path


USAGE_KEYS = ("input_tokens", "cached_input_tokens", "output_tokens",
              "reasoning_output_tokens", "total_tokens")
CALL_TYPES = {"function_call", "custom_tool_call"}
OUTPUT_TYPES = {"function_call_output", "custom_tool_call_output"}
COMPACTION_TYPES = {"compacted", "context_compacted"}
MAX_DIAGNOSTIC_ROWS = 20


def parse_timestamp(value: object) -> datetime | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        try:
            parsed = datetime.strptime(value[:16], "%Y%m%dT%H%M%SZ").replace(
                tzinfo=timezone.utc,
            )
        except ValueError:
            return None
    return parsed if parsed.tzinfo else parsed.replace(tzinfo=timezone.utc)


def read_records(path: Path) -> list[dict]:
    records = []
    with path.open(encoding="utf-8", errors="replace") as stream:
        for line in stream:
            try:
                value = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(value, dict):
                records.append(value)
    return records


def metadata(records: list[dict]) -> dict:
    for record in records:
        if record.get("type") == "session_meta" and isinstance(record.get("payload"), dict):
            return record["payload"]
    return {}


def metadata_from_file(path: Path) -> dict:
    try:
        with path.open(encoding="utf-8", errors="replace") as stream:
            for _, line in zip(range(20), stream):
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if record.get("type") == "session_meta" \
                        and isinstance(record.get("payload"), dict):
                    return record["payload"]
    except OSError:
        pass
    return {}


def usage_dict(value: object) -> dict[str, int]:
    source = value if isinstance(value, dict) else {}
    result = {}
    for key in USAGE_KEYS:
        try:
            result[key] = max(0, int(source.get(key, 0) or 0))
        except (TypeError, ValueError):
            result[key] = 0
    return result


def efficiency_summary(usage: dict[str, int]) -> dict[str, int | float]:
    uncached_input = max(0, usage["input_tokens"] - usage["cached_input_tokens"])
    input_tokens = usage["input_tokens"]
    return {
        "raw_total_tokens": usage["total_tokens"],
        "cached_input_tokens": usage["cached_input_tokens"],
        "uncached_input_tokens": uncached_input,
        "effective_non_cached_tokens": uncached_input + usage["output_tokens"],
        "cached_input_ratio": round(usage["cached_input_tokens"] / input_tokens, 4)
        if input_tokens else 0.0,
    }


def output_text(value: object) -> str:
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        return "".join(str(part.get("text", "")) for part in value if isinstance(part, dict))
    return ""


def call_arguments(payload: dict) -> dict:
    value = payload.get("input", payload.get("arguments", {}))
    if isinstance(value, dict):
        return value
    if isinstance(value, str):
        try:
            parsed = json.loads(value)
        except json.JSONDecodeError:
            return {}
        return parsed if isinstance(parsed, dict) else {}
    return {}


def raw_call_arguments(payload: dict) -> str:
    value = payload.get("input", payload.get("arguments", ""))
    if isinstance(value, str):
        return value
    try:
        return json.dumps(value, sort_keys=True, separators=(",", ":"))
    except (TypeError, ValueError):
        return str(type(value).__name__)


def normalized_call_digest(payload: dict) -> str:
    """Fingerprint repeatable call shape without returning potentially sensitive arguments."""
    text = " ".join(raw_call_arguments(payload).split())
    text = re.sub(r"\b[0-9a-f]{8}-[0-9a-f-]{27,}\b", "<uuid>", text, flags=re.I)
    text = re.sub(r"\b\d{4}-\d{2}-\d{2}T[^\s\"']+", "<timestamp>", text)
    text = re.sub(r"\b\d{4,}\b", "<number>", text)
    return hashlib.sha256(text.encode()).hexdigest()[:16]


def tool_label(payload: dict) -> str:
    outer = str(payload.get("name") or "unknown")
    if outer != "exec":
        return outer
    match = re.search(r"\btools\.([A-Za-z0-9_]+)\s*\(", raw_call_arguments(payload))
    return match.group(1) if match else outer


def record_timestamp(record: dict) -> datetime | None:
    return parse_timestamp(record.get("timestamp"))


def before_retro_cutoff(records: list[dict]) -> list[dict]:
    # Long-lived threads can contain an earlier retro followed by more work. The current
    # report must stop at the latest retro request, not the first historical one.
    for index in range(len(records) - 1, -1, -1):
        record = records[index]
        payload = record.get("payload") if isinstance(record.get("payload"), dict) else {}
        if record.get("type") != "response_item" or payload.get("type") != "message" \
                or payload.get("role") != "user":
            continue
        if "session-retro" in output_text(payload.get("content")).lower():
            return records[:index]
    return records


def summarize(path: Path, is_descendant: bool, before_retro: bool = False) -> dict:
    records = read_records(path)
    original_record_count = len(records)
    if before_retro:
        records = before_retro_cutoff(records)
    meta = metadata(records)
    timestamps = [parsed for record in records
                  if (parsed := parse_timestamp(record.get("timestamp"))) is not None]
    token_events: list[tuple[int, str | None, dict]] = []
    task_starts: list[int] = []
    trigger_turn_indices: list[int] = []
    for index, record in enumerate(records):
        payload = record.get("payload") if isinstance(record.get("payload"), dict) else {}
        if record.get("type") == "event_msg" and payload.get("type") == "task_started":
            task_starts.append(index)
        if record.get("type") == "inter_agent_communication_metadata" \
                and payload.get("trigger_turn") is True:
            trigger_turn_indices.append(index)
    task_started_index = task_starts[0] if task_starts else None
    activity_boundary_method = "first_task_started"
    if is_descendant and trigger_turn_indices:
        # A Codex fork rollout can begin with a replay of the parent's complete event stream,
        # including several old task_started/token_count records. The trigger_turn marker belongs
        # to the fresh child turn; the last task_started before it is the real activity boundary.
        trigger_index = trigger_turn_indices[0]
        candidates = [index for index in task_starts if index < trigger_index]
        if candidates:
            task_started_index = candidates[-1]
            activity_boundary_method = "last_task_started_before_trigger_turn"
    tool_calls = forks = all_forks = compactions = truncations = output_bytes = 0
    fork_modes: Counter[str] = Counter()
    tool_histogram: Counter[str] = Counter()
    call_shapes: Counter[tuple[str, str]] = Counter()
    call_shape_bytes: dict[tuple[str, str], int] = {}
    pending_calls: dict[str, tuple[str, datetime | None, str, int]] = {}
    pending_order: deque[tuple[str, str, datetime | None, str, int]] = deque()
    largest_outputs: list[dict] = []
    elapsed_by_tool: defaultdict[str, list[int]] = defaultdict(list)
    for index, record in enumerate(records):
        payload = record.get("payload") if isinstance(record.get("payload"), dict) else {}
        payload_type = payload.get("type")
        if record.get("type") == "event_msg" and payload_type == "token_count":
            info = payload.get("info")
            if isinstance(info, dict) and isinstance(info.get("total_token_usage"), dict):
                timestamp = record.get("timestamp") if isinstance(record.get("timestamp"), str) \
                    else None
                token_events.append((index, timestamp, info))
        active = not is_descendant or task_started_index is None or index >= task_started_index
        if not active:
            continue
        if record.get("type") in COMPACTION_TYPES or payload_type in COMPACTION_TYPES:
            compactions += 1
        if record.get("type") == "response_item" and payload_type in CALL_TYPES:
            tool_calls += 1
            tool_name = tool_label(payload)
            tool_histogram[tool_name] += 1
            digest = normalized_call_digest(payload)
            shape = (tool_name, digest)
            call_shapes[shape] += 1
            argument_bytes = len(raw_call_arguments(payload).encode())
            call_shape_bytes[shape] = argument_bytes
            call_id = str(payload.get("call_id") or payload.get("id") or "")
            started = record_timestamp(record)
            if call_id:
                pending_calls[call_id] = (tool_name, started, digest, argument_bytes)
            pending_order.append((call_id, tool_name, started, digest, argument_bytes))
            if tool_name.split(".")[-1] == "spawn_agent":
                forks += 1
                mode = str(call_arguments(payload).get("fork_turns", "unspecified"))
                fork_modes[mode] += 1
                if mode == "all":
                    all_forks += 1
        if record.get("type") == "response_item" and payload_type in OUTPUT_TYPES:
            text = output_text(payload.get("output"))
            byte_count = len(text.encode("utf-8"))
            output_bytes += byte_count
            truncated = "Warning: truncated output" in text or "tokens truncated" in text
            if truncated:
                truncations += 1
            call_id = str(payload.get("call_id") or "")
            matched = pending_calls.pop(call_id, None) if call_id else None
            matched_by_id = matched is not None
            if matched is not None:
                tool_name, started, digest, argument_bytes = matched
                pending_order = deque(item for item in pending_order if item[0] != call_id)
            elif pending_order:
                _, tool_name, started, digest, argument_bytes = pending_order.popleft()
            else:
                tool_name, started, digest, argument_bytes = "unknown", None, "", 0
            largest_outputs.append({
                "tool": tool_name,
                "output_bytes": byte_count,
                "truncated": truncated,
                "attribution": "call_id" if matched_by_id else "sequence",
                "normalized_arguments_sha256": digest,
                "argument_bytes": argument_bytes,
            })
            finished = record_timestamp(record)
            if matched_by_id and started is not None and finished is not None:
                elapsed_by_tool[tool_name].append(
                    max(0, round((finished - started).total_seconds() * 1000))
                )

    gross = usage_dict(token_events[-1][2]["total_token_usage"]) \
        if token_events else usage_dict({})
    baseline = usage_dict({})
    baseline_known = not is_descendant
    baseline_method = "not_applicable_root"
    unique = gross.copy()
    if is_descendant:
        baseline_method = "unavailable_no_pre_task_total_usage"
        if task_started_index is not None:
            eligible = [info for index, _, info in token_events if index < task_started_index]
            if eligible:
                baseline = usage_dict(eligible[-1]["total_token_usage"])
                baseline_known = True
                baseline_method = "last_total_usage_before_activity_boundary"
                unique = {key: max(0, gross[key] - baseline[key]) for key in USAGE_KEYS}
            else:
                # No cumulative usage precedes the child's first real task, so the cumulative
                # total is already child-unique. Do not sum last_token_usage events: Codex may
                # repeat a final token_count record, which can make that sum exceed gross usage.
                baseline_known = True
                baseline_method = "zero_no_usage_before_activity_boundary"
        else:
            baseline_method = "unavailable_no_task_started"
    return {
        "session_id": meta.get("id") or meta.get("session_id"),
        "parent_thread_id": meta.get("parent_thread_id"),
        "agent_path": meta.get("agent_path"),
        "file": str(path.resolve()),
        "records_analyzed": len(records),
        "before_retro_cutoff_applied": len(records) < original_record_count,
        "started_at": min(timestamps).isoformat() if timestamps else None,
        "ended_at": max(timestamps).isoformat() if timestamps else None,
        "usage_available": bool(token_events),
        "usage_gross": gross,
        "inherited_fork_baseline": baseline,
        "inherited_fork_baseline_tokens": baseline["total_tokens"],
        "fork_baseline_known": baseline_known,
        "fork_baseline_method": baseline_method,
        "activity_boundary_method": activity_boundary_method if task_started_index is not None
        else "unavailable_no_task_started",
        "activity_boundary_known": not is_descendant or task_started_index is not None,
        "usage_unique": unique,
        "tool_calls": tool_calls,
        "tool_histogram": dict(sorted(tool_histogram.items())),
        "repeated_tool_calls": [
            {"tool": tool, "count": count, "normalized_arguments_sha256": digest,
             "argument_bytes": call_shape_bytes[(tool, digest)]}
            for (tool, digest), count in sorted(
                call_shapes.items(), key=lambda item: (-item[1], item[0])
            ) if count > 1
        ][:MAX_DIAGNOSTIC_ROWS],
        "_tool_call_shapes": [
            {"tool": tool, "count": count, "normalized_arguments_sha256": digest,
             "argument_bytes": call_shape_bytes[(tool, digest)]}
            for (tool, digest), count in call_shapes.items()
        ],
        "largest_tool_outputs": sorted(
            largest_outputs, key=lambda item: (-item["output_bytes"], item["tool"])
        )[:MAX_DIAGNOSTIC_ROWS],
        "tool_elapsed_ms": {
            tool: {"measured_calls": len(values), "total": sum(values),
                   "max": max(values)}
            for tool, values in sorted(elapsed_by_tool.items()) if values
        },
        "forks": forks,
        "fork_turns_modes": dict(sorted(fork_modes.items())),
        "all_forks": all_forks,
        "truncations": truncations,
        "compactions": compactions,
        "tool_output_bytes": output_bytes,
        "session_log_bytes": path.stat().st_size,
    }


def external_usage(directory: Path | None, session_ids: set[str],
                   window_start: datetime | None, window_end: datetime | None) -> dict:
    empty = {"sidecars": 0, "available_runs": 0, "unavailable_runs": 0,
             "unattributed_sidecars": 0, "unrelated_sidecars": 0, "invalid_sidecars": 0,
             "usage": usage_dict({}), "duration_ms": 0,
             "models": {}, "repos": {}, "providers": {}, "status": "unavailable"}
    if directory is None or not directory.exists():
        return empty
    sidecars = available = unavailable = unattributed = unrelated = invalid = duration_ms = 0
    total = usage_dict({})
    models: Counter[str] = Counter()
    repos: Counter[str] = Counter()
    providers: Counter[str] = Counter()
    for path in sorted(directory.glob("*.json")):
        try:
            record = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            invalid += 1
            continue
        thread_id = record.get("orchestrator_thread_id") if isinstance(record, dict) else None
        if not thread_id or str(thread_id) not in session_ids:
            sidecar_time = parse_timestamp(record.get("started_at") if isinstance(record, dict)
                                           else None) or parse_timestamp(path.name)
            grace = timedelta(minutes=5)
            if sidecar_time is not None and window_start is not None and window_end is not None \
                    and window_start - grace <= sidecar_time <= window_end + grace:
                unattributed += 1
            else:
                unrelated += 1
            continue
        sidecars += 1
        try:
            duration_ms += max(0, int(record.get("duration_ms", 0) or 0))
        except (TypeError, ValueError):
            pass
        models[str(record.get("model") or "provider_default")] += 1
        repos[str(record.get("repo") or "unavailable")] += 1
        providers[str(record.get("provider") or "unavailable")] += 1
        usage = record.get("usage")
        if isinstance(usage, dict) and record.get("usage_available") is True:
            available += 1
            for key, value in usage_dict(usage).items():
                total[key] += value
        else:
            unavailable += 1
    status = "unavailable" if sidecars == 0 else ("complete" if unavailable == 0 else "partial")
    return {"sidecars": sidecars, "available_runs": available,
            "unavailable_runs": unavailable, "unattributed_sidecars": unattributed,
            "unrelated_sidecars": unrelated, "invalid_sidecars": invalid,
            "usage": total, "duration_ms": duration_ms, "models": dict(sorted(models.items())),
            "repos": dict(sorted(repos.items())), "providers": dict(sorted(providers.items())),
            "status": status}


def discover_descendants(search_root: Path, root_path: Path, root_ids: set[str]) \
        -> tuple[list[Path], int]:
    by_parent: dict[str, list[tuple[Path, set[str]]]] = defaultdict(list)
    for path in search_root.rglob("*.jsonl"):
        if path.resolve() == root_path.resolve():
            continue
        meta = metadata_from_file(path)
        parent = meta.get("parent_thread_id")
        ids = {str(value) for value in (meta.get("id"), meta.get("session_id")) if value}
        if parent and ids:
            by_parent[str(parent)].append((path, ids))
    queue = deque((root_id, 0) for root_id in root_ids)
    visited_ids = set(root_ids)
    visited_paths: set[Path] = set()
    descendants: list[Path] = []
    direct_paths: set[Path] = set()
    while queue:
        parent_id, depth = queue.popleft()
        for path, ids in sorted(by_parent.get(parent_id, []), key=lambda item: str(item[0])):
            resolved = path.resolve()
            if resolved in visited_paths:
                continue
            visited_paths.add(resolved)
            descendants.append(path)
            if depth == 0:
                direct_paths.add(resolved)
            for session_id in ids:
                if session_id not in visited_ids:
                    visited_ids.add(session_id)
                    queue.append((session_id, depth + 1))
    return descendants, len(direct_paths)


def main() -> None:
    parser = argparse.ArgumentParser(prog="workflow-efficiency-report")
    parser.add_argument("root_session", type=Path)
    parser.add_argument("--sessions-root", type=Path,
                        help="directory searched recursively for descendant rollouts")
    parser.add_argument("--external-usage-dir", type=Path,
                        default=Path.home() / ".cache/agent-workflows/external-agent-usage")
    parser.add_argument("--max-descendants", type=int, default=100)
    parser.add_argument(
        "--before-retro", action="store_true",
        help="exclude the latest user session-retro request and all later records",
    )
    args = parser.parse_args()
    root_records = read_records(args.root_session)
    root_meta = metadata(root_records)
    root_ids = {str(value) for value in (root_meta.get("id"), root_meta.get("session_id")) if value}
    search_root = args.sessions_root or args.root_session.parent
    if args.sessions_root is None:
        for ancestor in args.root_session.parents:
            if ancestor.name == "sessions":
                search_root = ancestor
                break
    descendants, direct_children = discover_descendants(search_root, args.root_session, root_ids)
    selected = descendants[:max(0, args.max_descendants)]
    sessions = [summarize(args.root_session, False, args.before_retro)] \
        + [summarize(path, True, args.before_retro) for path in selected]
    tree_usage = usage_dict({})
    totals = {key: 0 for key in ("tool_calls", "forks", "all_forks", "truncations",
                                  "compactions", "tool_output_bytes", "session_log_bytes")}
    fork_modes: Counter[str] = Counter()
    tool_histogram: Counter[str] = Counter()
    repeated_calls: Counter[tuple[str, str, int]] = Counter()
    largest_outputs: list[dict] = []
    elapsed_by_tool: defaultdict[str, list[int]] = defaultdict(list)
    for session in sessions:
        for key, value in session["usage_unique"].items():
            tree_usage[key] += value
        for key in totals:
            totals[key] += session[key]
        fork_modes.update(session["fork_turns_modes"])
        tool_histogram.update(session["tool_histogram"])
        for row in session.pop("_tool_call_shapes"):
            repeated_calls[(row["tool"], row["normalized_arguments_sha256"],
                            row["argument_bytes"])] += row["count"]
        largest_outputs.extend(session["largest_tool_outputs"])
        for tool, values in session["tool_elapsed_ms"].items():
            elapsed_by_tool[tool].extend([values["total"], values["max"],
                                         values["measured_calls"]])
    session_ids = {str(session["session_id"]) for session in sessions if session["session_id"]}
    starts = [value for session in sessions
              if (value := parse_timestamp(session.get("started_at"))) is not None]
    ends = [value for session in sessions
            if (value := parse_timestamp(session.get("ended_at"))) is not None]
    external = external_usage(
        args.external_usage_dir, session_ids,
        min(starts) if starts else None, max(ends) if ends else None,
    )
    whole_tree_usage = {key: tree_usage[key] + external["usage"][key] for key in USAGE_KEYS}
    baselines_complete = all(session["fork_baseline_known"] for session in sessions)
    activity_complete = all(session["activity_boundary_known"] for session in sessions)
    report = {
        "root_session_id": root_meta.get("id") or root_meta.get("session_id"),
        "agents": len(sessions),
        "direct_children": direct_children,
        "descendants_discovered": len(descendants),
        "descendants_reported": len(selected),
        "descendants_truncated": len(descendants) > len(selected),
        "whole_tree_usage": whole_tree_usage,
        "whole_tree_efficiency": efficiency_summary(whole_tree_usage),
        "codex_tree_usage_unique": tree_usage,
        "codex_tree_efficiency": efficiency_summary(tree_usage),
        **totals,
        "fork_turns_modes": dict(sorted(fork_modes.items())),
        "tool_histogram": dict(sorted(tool_histogram.items())),
        "repeated_tool_calls": [
            {"tool": tool, "count": count, "normalized_arguments_sha256": digest,
             "argument_bytes": argument_bytes}
            for (tool, digest, argument_bytes), count in sorted(
                repeated_calls.items(), key=lambda item: (-item[1], item[0])
            )
        ][:MAX_DIAGNOSTIC_ROWS],
        "largest_tool_outputs": sorted(
            largest_outputs, key=lambda item: (-item["output_bytes"], item["tool"])
        )[:MAX_DIAGNOSTIC_ROWS],
        "tool_elapsed_ms": {
            tool: {
                "total": sum(values[0::3]),
                "max": max(values[1::3]),
                "measured_calls": sum(values[2::3]),
            }
            for tool, values in sorted(elapsed_by_tool.items()) if values
        },
        "sessions": sessions,
        "external_provider_usage": external,
        "coverage": {
            "codex_usage": "complete" if all(s["usage_available"] for s in sessions)
            else "partial",
            "descendants": "truncated" if len(descendants) > len(selected) else "complete",
            "fork_baselines": "complete" if baselines_complete else "uncertain",
            "fork_baseline_method": "per_session",
            "activity_boundaries": "complete" if activity_complete else "uncertain",
            "external_usage": external["status"],
        },
    }
    print(json.dumps(report, separators=(",", ":")))


if __name__ == "__main__":
    main()
