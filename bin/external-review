#!/usr/bin/env bash
# external-review — backward-compatible shim.
#
# Cross-provider review is now one mode of the generalized `external-agent` adapter.
# This wrapper preserves the original `external-review --provider … --base … --out …`
# interface (used by skills/review/SKILL.md and documented in README.md) by forwarding
# to `external-agent --task review`. All flags pass through unchanged.
#
# Resolve our own real location through any symlink chain (this script is typically run
# via a ~/.local/bin/external-review symlink), so we always find the external-agent that
# lives next to the *real* script — not whatever happens to sit beside the symlink.
target="${BASH_SOURCE[0]}"
while [ -L "$target" ]; do
  dir="$(cd -P "$(dirname "$target")" >/dev/null 2>&1 && pwd)"
  target="$(readlink "$target")"
  [[ $target != /* ]] && target="$dir/$target"
done
dir="$(cd -P "$(dirname "$target")" >/dev/null 2>&1 && pwd)"
exec "$dir/external-agent" --task review "$@"
