#!/usr/bin/env python3
"""external-build — run the Codex CLI (GPT 5.6) as a WRITE-ENABLED builder for one bounded unit of
implementation work, and return the structured JSON the build/resolve orchestrators expect.

This is the builder counterpart of `external-agent`. It is deliberately a SEPARATE binary:
`external-agent` runs peers read-only with schema-constrained advisory output, and that
contract is load-bearing for review safety. external-build is the one sanctioned write path
to a peer provider.

Used by `/build --builder codex` and `/resolve-review --builder codex`. The dispatching
orchestrator — not this builder — owns all MCP artifact status updates, validation gates,
and every commit. The Codex side gets no MCP access and is forbidden from committing, so
each dispatched chain packet must be self-contained (see skills/create-build-todos).

Tasks (--task):

  build    Implement one coherent sequential build_todo chain. Prints one JSON object matching
           the build-mode
           contract in agents/builder.md:
               { "chain_status": "complete|failed|needs_replan",
                 "todo_results":[...], "files_changed":[...], "deviations":[...],
                 "risks_unverified":[...], "error" }

  resolve  Apply a batch of review findings. Prints a JSON array, one entry per finding,
           matching the resolve-mode contract in agents/builder.md:
               [ { "finding_id", "status": "resolved|skipped|deferred",
                   "files_changed":[...], "risks_unverified":[...],
                   "suggested_validation":[...], "regression_test" } ]

Model and reasoning effort default here (gpt-5.6 / medium) so runs do not drift with the
user's ~/.codex/config.toml. Escalate per dispatch via --reasoning: `high` for
cross-cutting logic, concurrency, or migration work; `xhigh` only when retrying after a
measured lower-effort failure (see skills/references/model-prompting.md).

Usage:
    external-build --task build   --todo-file F [--context-file F] --memory-context-file F [common]
    external-build --task resolve --findings-file F [--context-file F] --memory-context-file F [common]
  common: [--repo DIR] [--model gpt-5.6] [--reasoning medium|high|xhigh] [--timeout SECS]
          [--out FILE] [--sandbox workspace-write|danger-full-access]

--context-file carries bounded orchestrator-supplied context: relevant plan/contract excerpt,
affected paths/interfaces, predecessor tree SHA, named orchestrator validation commands, relevant
memory-service gotchas (the Codex side cannot search memory itself), and — on a self-repair retry —
the previous attempt's error and unverified risks.

Exit codes: 0 ok; 2 codex produced no valid output (a valid `failed` result is still
printed so the caller's retry loop stays uniform); 1 usage/setup error.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "hooks"))
from memory_context import confirm_packet_delivery  # noqa: E402

DEFAULT_MODEL = "gpt-5.6"
DEFAULT_REASONING = "medium"
DEFAULT_TIMEOUT = 3600  # escalated reasoning on a real todo can take tens of minutes

BUILD_SCHEMA = {
    "type": "object",
    "properties": {
        "chain_status": {
            "type": "string", "enum": ["complete", "failed", "needs_replan"],
        },
        "todo_results": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "todo_id": {"type": "string"},
                    "status": {
                        "type": "string",
                        "enum": ["complete", "failed", "needs_replan"],
                    },
                    "files_changed": {"type": "array", "items": {"type": "string"}},
                    "deviations": {"type": "array", "items": {"type": "string"}},
                    "risks_unverified": {"type": "array", "items": {"type": "string"}},
                },
                "required": [
                    "todo_id", "status", "files_changed", "deviations", "risks_unverified",
                ],
                "additionalProperties": False,
            },
        },
        "files_changed": {"type": "array", "items": {"type": "string"}},
        "deviations": {"type": "array", "items": {"type": "string"}},
        "risks_unverified": {"type": "array", "items": {"type": "string"}},
        "error": {"type": ["string", "null"]},
    },
    "required": [
        "chain_status", "todo_results", "files_changed", "deviations", "risks_unverified", "error",
    ],
    "additionalProperties": False,
}

RESOLVE_ENTRY_SCHEMA = {
    "type": "object",
    "properties": {
        "finding_id": {"type": "string"},
        "status": {"type": "string", "enum": ["resolved", "skipped", "deferred"]},
        "files_changed": {"type": "array", "items": {"type": "string"}},
        "risks_unverified": {"type": "array", "items": {"type": "string"}},
        "suggested_validation": {"type": "array", "items": {"type": "string"}},
        "regression_test": {"type": ["string", "null"]},
    },
    "required": [
        "finding_id", "status", "files_changed", "risks_unverified", "suggested_validation",
        "regression_test",
    ],
    "additionalProperties": False,
}

# Codex --output-schema wants an object root; the adapter unwraps `results` for the caller.
RESOLVE_SCHEMA = {
    "type": "object",
    "properties": {"results": {"type": "array", "items": RESOLVE_ENTRY_SCHEMA}},
    "required": ["results"],
    "additionalProperties": False,
}

# The Codex builder contract: hard invariants, validation ownership, and honest-output
# rules only. Keep it lean per skills/references/model-prompting.md — GPT-5.6 performs
# better without step-by-step scaffolding; add prescriptive checklists only in a legacy
# (gpt-5.5) dispatch, not here.
COMMON_RULES = """\
You are a code builder working inside this repository's working tree.

HARD RULES (never violate):
- NEVER run `git commit`, `git push`, `git checkout -b`, `git switch -c`, or open a PR.
  You change the working tree only; the orchestrator owns all git history operations.
- NEVER call MCP tools or any ticket/memory system. The orchestrator owns artifact statuses.
- Do not add features, refactor, or introduce abstractions beyond what the task requires.
  Do the simplest thing that works well. No backwards-compatibility shims; delete replaced
  code completely.
- No `Any` types (TypeScript or Python). No `type: ignore`. Imports only at top of file.
- Match the existing code style of each file you touch. Follow the discovered patterns
  given in the task EXACTLY — they were researched from this codebase.
- Before removing any export/class/function, search ALL usages across the codebase first.

QUALITY LOOP (each change):
1. Read the target files and the closest analogous module named in the task before writing.
2. Implement the change.
3. Inspect the edited code and interfaces before moving on.
4. Count-inspect bulk changes (grep to confirm the expected number of occurrences).

VALIDATION OWNERSHIP:
- NEVER run test suites, validation commands, typecheck, lint, builds, schema pulls,
  migrations, browser verification, or health commands.
- Report unverified risks and exact suggested commands for the orchestrator; do not execute them.

SCHEMA PARITY: if you modify model/schema files, the repo's active schema-deploy artifact
must exist (Atlas plan / Prisma / Alembic migration — check the repo's CLAUDE.md for which
system is active). You may write the artifact but must not execute schema or migration commands.
If you cannot produce it, return chain_status "failed" with the missing-schema reason in `error` —
omitting it means the column/object may not exist at runtime.

Your FINAL message must be exactly the JSON object required by the output schema — no prose.
Report honestly: implementation completion is not validation evidence; put unverified items in
`risks_unverified`.
"""

BUILD_TASK_RULES = """\
TASK: implement ONLY the coherent sequential build_todo chain given below, in order.

- If the todo itself is wrong — it contradicts the code you find, or the design does not
  hold — STOP at that todo and return chain_status "needs_replan" with the reason in `error`.
  Do not improvise a different design to force the chain closed.
- If this todo implements a repeated writer (poller, observer, scheduler, queue, webhook,
  scraper) and the design would persist duplicate unchanged source data proportional to
  polling frequency, return chain_status "needs_replan" unless the todo names the downstream
  consumer, volume budget, dedupe/change-gating behavior, and retention/TTL for that history.
- Return one `todo_results` mapping for every todo reached in the chain. A "complete" mapping means
  its implementation is present and inspected; validation remains orchestrator-owned.
"""

RESOLVE_TASK_RULES = """\
TASK: apply the review-finding fixes given below. One result entry per finding.

- Implement each fix exactly as specified (the orchestrator already made the accept/modify
  decisions). Do not re-litigate the finding.
- Do not run validation. Report unverified risks and exact suggested orchestrator commands.
- For every p1 correctness fix: add a regression test
  and name it in `regression_test`, or state an explicit reason the fix is untestable.
  Use null for non-p1 findings.
- If a fix cannot be applied safely, return that entry as "deferred" and say why in its
  `risks_unverified`.
"""


def die(msg: str) -> None:
    print(f"external-build: {msg}", file=sys.stderr)
    sys.exit(1)


def read_file(path: str, what: str) -> str:
    p = Path(path)
    if not p.is_file():
        die(f"{what} not found: {path}")
    return p.read_text(encoding="utf-8")


def read_memory_context(path: str | None) -> str:
    if not path:
        return ""
    packet = read_file(path, "memory context file").strip()
    if len(packet) > 3_000:
        die("memory context exceeds the 3000-character external-task budget")
    if packet.count("<autodev-memory-task-context") != 1 or \
            packet.count("</autodev-memory-task-context>") != 1:
        die("memory context must contain exactly one bounded task-context envelope")
    return packet


def failed_result(task: str, reason: str):
    if task == "build":
        return {"chain_status": "failed", "todo_results": [], "files_changed": [],
                "deviations": [], "risks_unverified": [reason], "error": reason}
    return []  # resolve: empty array — every finding stays pending, caller re-dispatches


def run_codex(full_prompt: str, schema: dict, model: str, reasoning: str, sandbox: str,
              repo: Path, timeout: int) -> str:
    with tempfile.TemporaryDirectory() as td:
        schema_file = Path(td) / "schema.json"
        last_file = Path(td) / "last.json"
        schema_file.write_text(json.dumps(schema), encoding="utf-8")
        # `-c mcp_servers={}` makes the no-MCP contract real: Codex loads zero MCP servers
        # regardless of the user's ~/.codex/config.toml (value parses as an empty TOML table).
        common = ["-s", sandbox,
                  "-m", model,
                  "-c", f"model_reasoning_effort={reasoning}",
                  "-c", "mcp_servers={}",
                  "--output-schema", str(schema_file),
                  "-o", str(last_file)]
        env = os.environ.copy()
        env["AUTODEV_MEMORY_EXPLICIT_PACKET"] = "1"

        def read_last() -> str:
            if last_file.is_file() and last_file.read_text(encoding="utf-8").strip():
                return last_file.read_text(encoding="utf-8")
            return ""

        cmd = ["codex", "exec", "--skip-git-repo-check", "-C", str(repo)] + common
        try:
            res = subprocess.run(
                cmd, input=full_prompt, text=True, timeout=timeout, env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE)
        except subprocess.TimeoutExpired:
            print(f"external-build: codex timed out after {timeout}s", file=sys.stderr)
            return ""
        out = read_last()
        if out:
            return out
        err = (res.stderr or "").strip()
        if err:
            print("external-build: codex produced no output; stderr tail:\n"
                  + err[-800:], file=sys.stderr)
        return ""


def main() -> None:
    ap = argparse.ArgumentParser(prog="external-build", add_help=True)
    ap.add_argument("--task", required=True, choices=["build", "resolve"])
    ap.add_argument("--todo-file", help="file containing one coherent build_todo chain (task build)")
    ap.add_argument("--findings-file",
                    help="file containing the findings batch to fix (task resolve)")
    ap.add_argument("--context-file",
                    help="bounded orchestrator context: relevant contract, paths/interfaces, "
                         "tree SHA, named validation commands, gotchas, prior-attempt error")
    ap.add_argument("--memory-context-file", required=True,
                    help="one explicit <=3K memory task packet; suppresses ambient hooks")
    ap.add_argument(
        "--telemetry-file", type=Path,
        default=Path.home() / ".cache/autodev-memory/telemetry.jsonl",
    )
    ap.add_argument("--repo", default=".", help="repo working directory (default: cwd)")
    ap.add_argument("--model", default=DEFAULT_MODEL)
    ap.add_argument("--reasoning", default=DEFAULT_REASONING,
                    choices=["low", "medium", "high", "xhigh"])
    ap.add_argument("--sandbox", default="workspace-write",
                    choices=["workspace-write", "danger-full-access"])
    ap.add_argument("--timeout", type=int, default=DEFAULT_TIMEOUT)
    ap.add_argument("--out", help="also write the result JSON to this file")
    args = ap.parse_args()

    repo = Path(args.repo).resolve()
    if not repo.is_dir():
        die(f"repo dir not found: {repo}")

    if args.task == "build":
        if not args.todo_file:
            die("--todo-file is required for --task build")
        work = read_file(args.todo_file, "todo file")
        task_rules = BUILD_TASK_RULES
        schema = BUILD_SCHEMA
        work_header = "BUILD TODO CHAIN (implement only these todos, in order):"
    else:
        if not args.findings_file:
            die("--findings-file is required for --task resolve")
        work = read_file(args.findings_file, "findings file")
        task_rules = RESOLVE_TASK_RULES
        schema = RESOLVE_SCHEMA
        work_header = "REVIEW FINDINGS TO FIX (already approved by the orchestrator):"

    context = read_file(args.context_file, "context file") if args.context_file else ""
    memory_context = read_memory_context(args.memory_context_file)

    parts = [COMMON_RULES, task_rules]
    if context.strip():
        parts.append("BOUNDED ORCHESTRATOR CONTEXT (relevant contract, paths/interfaces, "
                     "tree SHA, named validation commands, known gotchas, prior attempt):\n"
                     + context)
    if memory_context:
        parts.append("EXPLICIT MEMORY TASK CONTEXT (bounded; expand/search only when needed):\n"
                     + memory_context)
    parts.append(work_header + "\n" + work)
    prompt = "\n\n---\n\n".join(parts)

    raw = run_codex(prompt, schema, args.model, args.reasoning, args.sandbox, repo, args.timeout)

    exit_code = 0
    result = None
    if raw:
        try:
            result = json.loads(raw)
        except json.JSONDecodeError as e:
            print(f"external-build: codex output was not valid JSON: {e}", file=sys.stderr)
    if result is not None:
        valid_shape = (
            isinstance(result, dict)
            and (
                args.task == "build"
                and result.get("chain_status") in {"complete", "failed", "needs_replan"}
                or args.task == "resolve" and isinstance(result.get("results"), list)
            )
        )
        if not valid_shape:
            result = None
    if result is None:
        result = failed_result(args.task, "codex produced no valid structured output "
                                          "(timeout, crash, or schema violation)")
        exit_code = 2
    else:
        confirm_packet_delivery(
            memory_context,
            provider="codex",
            mechanism="external_build",
            confirmation_stage="validated_provider_response",
            telemetry_file=args.telemetry_file,
        )
        if args.task == "resolve":
            result = result.get("results", [])

    out_text = json.dumps(result, indent=2)
    if args.out:
        Path(args.out).write_text(out_text + "\n", encoding="utf-8")
    print(out_text)
    sys.exit(exit_code)


if __name__ == "__main__":
    main()
