#!/usr/bin/env python3
"""Run a command while keeping its complete output out of the agent context."""

from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import time
import uuid
from pathlib import Path


def main() -> None:
    parser = argparse.ArgumentParser(prog="compact-exec")
    parser.add_argument("--run-dir", type=Path,
                        default=Path.home() / ".cache/agent-workflows/compact-exec")
    parser.add_argument("--tail-bytes", type=int, default=4096)
    parser.add_argument("--timeout", type=float)
    parser.add_argument("command", nargs=argparse.REMAINDER)
    args = parser.parse_args()
    command = args.command[1:] if args.command[:1] == ["--"] else args.command
    if not command:
        parser.error("a command is required after --")
    if not 0 <= args.tail_bytes <= 8192:
        parser.error("--tail-bytes must be between 0 and 8192")

    run_id = f"{time.strftime('%Y%m%dT%H%M%SZ', time.gmtime())}-{uuid.uuid4().hex[:12]}"
    run_path = args.run_dir / run_id
    run_path.mkdir(parents=True, mode=0o700)
    output_path = run_path / "output.log"
    started = time.monotonic()
    timed_out = False
    with output_path.open("wb") as output:
        try:
            process = subprocess.Popen(command, stdout=output, stderr=subprocess.STDOUT,
                                       start_new_session=True)
            try:
                exit_code = process.wait(timeout=args.timeout)
            except subprocess.TimeoutExpired:
                timed_out = True
                exit_code = 124
                try:
                    os.killpg(process.pid, signal.SIGTERM)
                except OSError:
                    pass
                time.sleep(0.5)
                try:
                    os.killpg(process.pid, signal.SIGKILL)
                except OSError:
                    pass
                process.wait()
        except OSError as error:
            output.write(f"compact-exec: {error}\n".encode("utf-8", errors="replace"))
            exit_code = 127 if isinstance(error, FileNotFoundError) else 126
    duration_ms = round((time.monotonic() - started) * 1000)
    size = output_path.stat().st_size
    with output_path.open("rb") as output:
        output.seek(max(0, size - args.tail_bytes))
        tail = output.read().decode("utf-8", errors="replace")
    summary = {
        "run_id": run_id,
        "exit_code": exit_code,
        "timed_out": timed_out,
        "duration_ms": duration_ms,
        "output_bytes": size,
        "output_file": str(output_path.resolve()),
        "tail_truncated": size > args.tail_bytes,
        "tail": tail,
    }
    print(json.dumps(summary, separators=(",", ":")))
    raise SystemExit(exit_code)


if __name__ == "__main__":
    main()
