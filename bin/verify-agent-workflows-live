#!/usr/bin/env python3
"""Verify whether the user-level agent-workflows checkout contains a merged revision."""

from __future__ import annotations

import argparse
import json
import subprocess
from pathlib import Path


def git(repo: Path, *args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args], cwd=repo, capture_output=True, text=True, check=False,
    )


def resolve_live_repo(explicit: Path | None) -> Path | None:
    if explicit is not None:
        return explicit.expanduser().resolve()
    candidates = (
        Path.home() / ".local/bin/workflow-efficiency-report",
        Path.home() / ".agents/skills/session-retro",
        Path.home() / ".claude/skills/session-retro",
    )
    for candidate in candidates:
        if not candidate.exists() and not candidate.is_symlink():
            continue
        resolved = candidate.resolve()
        for parent in (resolved, *resolved.parents):
            if (parent / ".git").exists() and (parent / "CLAUDE.md").is_file():
                return parent
    return None


def main() -> None:
    parser = argparse.ArgumentParser(prog="verify-agent-workflows-live")
    parser.add_argument("expected_revision", help="merged SHA or ref that must be live")
    parser.add_argument("--live-repo", type=Path,
                        help="override the checkout resolved from user-level symlinks")
    args = parser.parse_args()

    repo = resolve_live_repo(args.live_repo)
    result: dict[str, object] = {
        "status": "unverifiable",
        "expected_revision": args.expected_revision,
        "live_repo": str(repo) if repo else None,
        "head": None,
        "dirty": None,
        "contains_expected_revision": False,
        "reason": None,
    }
    if repo is None:
        result["reason"] = "could not resolve a git checkout from user-level agent-workflow links"
        print(json.dumps(result, separators=(",", ":")))
        raise SystemExit(2)

    head = git(repo, "rev-parse", "HEAD")
    expected = git(repo, "rev-parse", "--verify", args.expected_revision)
    if head.returncode:
        result["reason"] = "live checkout HEAD is not resolvable"
        print(json.dumps(result, separators=(",", ":")))
        raise SystemExit(2)

    dirty_output = git(repo, "status", "--porcelain")
    dirty = bool(dirty_output.stdout.strip()) if dirty_output.returncode == 0 else None
    if expected.returncode:
        result.update({
            "head": head.stdout.strip(),
            "dirty": dirty,
            "status": "not_live",
            "reason": "expected revision is not present in the live checkout",
        })
        print(json.dumps(result, separators=(",", ":")))
        raise SystemExit(1)

    contains = git(repo, "merge-base", "--is-ancestor", expected.stdout.strip(), "HEAD").returncode == 0
    result.update({
        "head": head.stdout.strip(),
        "dirty": dirty,
        "contains_expected_revision": contains,
    })
    if not contains:
        result["status"] = "not_live"
        result["reason"] = "live checkout does not contain the merged revision"
        exit_code = 1
    elif dirty:
        result["status"] = "live_but_modified"
        result["reason"] = "merged revision is present but user-level files have local modifications"
        exit_code = 1
    else:
        result["status"] = "live"
        exit_code = 0
    print(json.dumps(result, separators=(",", ":")))
    raise SystemExit(exit_code)


if __name__ == "__main__":
    main()
