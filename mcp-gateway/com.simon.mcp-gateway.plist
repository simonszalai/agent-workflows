<?xml version="1.0" encoding="UTF-8"?>
<!-- Install: cp this to ~/Library/LaunchAgents/ then
     `launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.simon.mcp-gateway.plist`.
     The first start triggers at most ONE 1Password biometric prompt; if startup fails
     (missing op:// item, invalid account, bad config), start-gateway.sh posts one
     notification, logs the error, and exits cleanly. There is intentionally NO
     KeepAlive retry, because every retry would be another Touch ID prompt. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.simon.mcp-gateway</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/simon/dev/agent-workflows/mcp-gateway/start-gateway.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/mcp-gateway.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/mcp-gateway.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
