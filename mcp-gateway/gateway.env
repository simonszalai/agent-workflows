# mcp-gateway secret references — resolved by ONE `op run` at daemon start
# (single op process = single auth window = one biometric, no TCC prompt storm).
# Values never exist outside the gateway process env. E0022.
#
# Every secret the gateway needs is an op:// ref here — the daemon no longer
# reads the 1Password "MCP env" mount at all (that mount survives only for the
# project-mcp fallback / analyst path). Items live in per-project vaults:
# TS / TS-sensitive, AMARU / AMARU-sensitive, WORKFLOW / WORKFLOW-sensitive,
# AUTODEV-sensitive, MCP (shared tokens).
#
# DB refs point at the CANONICAL items (ts-prefect scripts/secrets canonical-
# only design): one external URL per tier; finish-start.zsh derives the prod
# prefect-db URL by swapping the database path segment. A missing ref
# crash-loops the daemon (throttled to one biometric per 2 min by the plist
# ThrottleInterval) — if that happens, the vault migration/rotation was
# interrupted; fix the vault, don't point the gateway elsewhere.

# TS
TS_RENDER_API_KEY=op://TS-sensitive/TS_RENDER_API_KEY/value
# Read-only role (E: agents must not write prod except via explicit approval).
# The write-capable canonical stays in op://TS-sensitive/PROD_POSTGRES_URL —
# never point the gateway back at it without Simon's explicit sign-off.
TS_PROD_POSTGRES_URL=op://TS/PROD_POSTGRES_URL_RO/value
TS_POSTGRES_STAGING_URL=op://TS/STAGING_POSTGRES_URL/value
TS_POSTGRES_DEV_URL=op://TS/DEV_POSTGRES_URL/value
TS_POSTGRES_AUTODEV_TS_URL=op://AUTODEV-sensitive/PROD_POSTGRES_URL/value
# ts/tailscale spawn child inherits these (API-scoped OAuth client, SA-readable TS
# vault). Any MCP that needs 1Password secrets routes through the gateway like this —
# never per-session `op read` in a repo .mcp.json (that's a fingerprint-prompt storm).
TAILSCALE_OAUTH_CLIENT_ID=op://TS/TAILSCALE_OAUTH_CLIENT_ID_MCP/value
TAILSCALE_OAUTH_CLIENT_SECRET=op://TS/TAILSCALE_OAUTH_CLIENT_SECRET_MCP/value

# AMARU
AMARU_RENDER_API_KEY=op://AMARU-sensitive/AMARU_RENDER_API_KEY/value
AMARU_POSTGRES_PROD_URL=op://AMARU-sensitive/PROD_POSTGRES_URL/value
AMARU_POSTGRES_STAGING_URL=op://AMARU/STAGING_POSTGRES_URL/value
AMARU_POSTGRES_DEV_URL=op://AMARU/DEV_POSTGRES_URL/value

# WORKFLOW
WORKFLOW_RENDER_API_KEY=op://WORKFLOW_PRO-sensitive/WORKFLOW_RENDER_API_KEY/value
WORKFLOW_POSTGRES_PROD_URL=op://WORKFLOW_PRO-sensitive/PROD_POSTGRES_URL/value
WORKFLOW_POSTGRES_STAGING_URL=op://WORKFLOW_PRO/STAGING_POSTGRES_URL/value
WORKFLOW_POSTGRES_DEV_URL=op://WORKFLOW_PRO/DEV_POSTGRES_URL/value

# AUTODEV / shared
AUTODEV_GLOBAL_POSTGRES_URL=op://AUTODEV-sensitive/PROD_POSTGRES_URL/value
AUTODEV_MEMORY_API_TOKEN=op://MCP/AUTODEV_MEMORY_API_TOKEN/value
CONTEXT7_API_KEY=op://MCP/CONTEXT7_API_KEY/value
# Read-only Slack user token for the official hosted Slack MCP server. Create the
# internal app from slack-app-manifest.yaml, install it as Simon, then store the
# resulting xoxp token in this item. Never use a bot token: bot identity cannot
# search Simon's DMs/private conversations with Thomas.
SLACK_MCP_USER_TOKEN=op://MCP/SLACK_MCP_USER_TOKEN/value
