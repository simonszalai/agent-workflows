{
  "_comment": "Path prefix -> upstream MCP. prefix = <project>/<server> (project carried in the URL = project-awareness). TWO route kinds: (1) remote HTTP upstreams have `target` (a real remote URL, never a localhost proxy) + `authEnv` (env var name the launchd wrapper exports from 1Password; tokens are NEVER stored here). (2) `spawn` routes are local stdio MCP servers the daemon supervises itself — it launches one long-lived process per entry, binds it to 127.0.0.1:<port>, and proxies to it; `target` is derived as http://127.0.0.1:<port>. Phase 1 = the remote HTTP servers (the mcp-remote proliferation). Phase 2 = postgres, folded in as `spawn` routes (replaces the per-workspace `project-mcp ts postgres_*` stdio spawns + their per-workspace 1Password reads). Render routes: the gateway auto-selects the workspace per MCP session (`renderWorkspace` pins the owner id; without it, list_workspaces auto-selects on single-workspace accounts) so clients never see 'no workspace set'.",
  "routes": {
    "shared/autodev-memory": {
      "target": "https://autodev-memory.onrender.com/mcp",
      "authEnv": "AUTODEV_MEMORY_API_TOKEN"
    },
    "shared/context7": {
      "target": "https://mcp.context7.com/mcp",
      "authHeader": "CONTEXT7_API_KEY",
      "authScheme": "",
      "authEnv": "CONTEXT7_API_KEY"
    },
    "ts/render": {
      "target": "https://mcp.render.com/mcp",
      "authEnv": "TS_RENDER_API_KEY",
      "renderWorkspace": "tea-ct11rp0gph6c73bf2kf0"
    },
    "amaru/render": {
      "target": "https://mcp.render.com/mcp",
      "authEnv": "AMARU_RENDER_API_KEY"
    },
    "workflow/render": {
      "target": "https://mcp.render.com/mcp",
      "authEnv": "WORKFLOW_RENDER_API_KEY"
    },

    "ts/postgres_dev": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "TS_POSTGRES_DEV_URL", "accessMode": "unrestricted", "port": 8811 }
    },
    "ts/postgres_staging": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "TS_POSTGRES_STAGING_URL", "accessMode": "unrestricted", "port": 8812 }
    },
    "ts/postgres_prod": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "TS_POSTGRES_PROD_URL", "accessMode": "restricted", "port": 8813 }
    },
    "ts/postgres_prod_prefect": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "TS_POSTGRES_PROD_PREFECT_URL", "accessMode": "unrestricted", "port": 8814 }
    },
    "ts/postgres_autodev_ts": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "TS_POSTGRES_AUTODEV_TS_URL", "accessMode": "unrestricted", "port": 8815 }
    },

    "amaru/postgres_dev": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "AMARU_POSTGRES_DEV_URL", "accessMode": "unrestricted", "port": 8821 }
    },
    "amaru/postgres_staging": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "AMARU_POSTGRES_STAGING_URL", "accessMode": "unrestricted", "port": 8822 }
    },
    "amaru/postgres_prod": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "AMARU_POSTGRES_PROD_URL", "accessMode": "restricted", "port": 8823 }
    },

    "workflow/postgres_dev": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "WORKFLOW_POSTGRES_DEV_URL", "accessMode": "unrestricted", "port": 8831 }
    },
    "workflow/postgres_staging": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "WORKFLOW_POSTGRES_STAGING_URL", "accessMode": "unrestricted", "port": 8832 }
    },
    "workflow/postgres_prod": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "WORKFLOW_POSTGRES_PROD_URL", "accessMode": "restricted", "port": 8833 }
    },

    "shared/postgres_autodev_global": {
      "spawn": { "kind": "postgres-mcp", "urlEnv": "AUTODEV_GLOBAL_POSTGRES_URL", "accessMode": "unrestricted", "port": 8841 }
    }
  }
}
